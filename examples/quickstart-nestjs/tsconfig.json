{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "glirastes": ["../../src/index.ts"],
      "glirastes/server": ["../../src/server/index.ts"],
      "glirastes/server/nestjs": ["../../src/server/adapters/nestjs/index.ts"]
    }
  },
  "include": ["**/*.ts"]
}
