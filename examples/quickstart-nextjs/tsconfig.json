{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "glirastes": ["../../src/index.ts"],
      "glirastes/server": ["../../src/server/index.ts"],
      "glirastes/server/nextjs": ["../../src/server/adapters/nextjs/index.ts"],
      "glirastes/react/vercel": ["../../src/react/transports/vercel/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
